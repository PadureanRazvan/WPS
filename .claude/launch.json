{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "wps",
      "runtimeExecutable": "C:\\Users\\USER\\AppData\\Local\\ms-playwright-go\\1.50.1\\node.exe",
      "runtimeArgs": ["-e", "const port=process.env.PORT||3001;require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),u=q.url.split('?')[0]==='/'?'/index.html':q.url.split('?')[0],f=p.join(process.cwd(),u),m={'.html':'text/html; charset=utf-8','.css':'text/css; charset=utf-8','.js':'application/javascript; charset=utf-8','.json':'application/json','.svg':'image/svg+xml','.png':'image/png','.jpg':'image/jpeg','.ico':'image/x-icon'};fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':m[p.extname(f)]||'application/octet-stream'});r.end(d)}})}).listen(port,()=>console.log('Server on port '+port))"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
