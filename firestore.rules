rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorizedStaff() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && (
          request.auth.token.email == 'reizvanmail@gmail.com'
          || request.auth.token.email.matches('^[^@]+@fspglobal[.]com$')
        );
    }

    match /agents/{agentId} {
      allow read, create, update, delete: if isAuthorizedStaff();
    }

    match /productivity/{dateId} {
      allow read, create, update, delete: if isAuthorizedStaff();
    }

    match /schedules/{monthId} {
      allow read, create, update, delete: if isAuthorizedStaff();
    }

    match /activity_logs/{logId} {
      allow read: if isAuthorizedStaff();
      allow create: if isAuthorizedStaff()
        && request.resource.data.user.uid == request.auth.uid;
    }

    // Gemini credentials are server secrets. Clients must never read or write them.
    match /config/{configId} {
      allow read, write: if false;
    }

    // Written only by the Admin SDK in the callable function.
    match /_server_ai_rate_limits/{userId} {
      allow read, write: if false;
    }
  }
}
